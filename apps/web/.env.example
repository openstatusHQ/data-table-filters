# Supabase Postgres direct connection string
# Find this in your Supabase dashboard: Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Vercel Cron secret (used to secure /api/cron/seed-logs)
CRON_SECRET=your-random-secret-min-16-chars

# Vercel AI Gateway API key (used by data-table-filter-command-ai block)
# Get one at https://vercel.com/docs/ai-gateway — only needed if using AI filters
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key

# Upstash Redis (optional — used for rate limiting AI builder generation)
# Get credentials at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
